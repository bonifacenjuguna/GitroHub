# ============================================
# GitroHub Bot — Environment Variables
# ============================================
# Copy this to Railway as ENV variables
# NEVER commit real values to GitHub

# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_ID=your_telegram_user_id_here

# GitHub OAuth App
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
# Use /auth/github/callback — standard OAuth path
# This is auto-built from WEBHOOK_URL, so you can omit this line
GITHUB_REDIRECT_URI=https://your-app.railway.app/auth/github/callback

# Database (Railway auto-fills this)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Encryption (generate with: python -c "import secrets; print(secrets.token_hex(32))")
AES_ENCRYPTION_KEY=your_32_byte_hex_key_here

# App
WEBHOOK_URL=https://your-app.railway.app
PORT=8080
